QWICKY_SUPABASE_SERVICE_KEY=

# Admin API auth (server-to-server callers: Discord bot via Fly.io)
ADMIN_API_KEY=

# Frontend Supabase client (browser session auth for protected API endpoints)
VITE_QWICKY_SUPABASE_URL=
VITE_QWICKY_SUPABASE_ANON_KEY=
